# Co-op Translator Configuration
# Copy this file to .env and fill in your credentials.
# See: https://github.com/Azure/co-op-translator

# =============================================================================
# Option A: Azure OpenAI (Recommended for Azure projects)
# =============================================================================
AZURE_OPENAI_API_KEY="your_azure_openai_api_key"
AZURE_OPENAI_ENDPOINT="https://your_endpoint.openai.azure.com/"
AZURE_OPENAI_MODEL_NAME="gpt-4o"
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME="your_deployment_name"
AZURE_OPENAI_API_VERSION="2024-12-01-preview"

# =============================================================================
# Option B: OpenAI (Alternative)
# =============================================================================
# OPENAI_API_KEY="your_openai_api_key"
# OPENAI_ORG_ID="your_openai_org_id"
# OPENAI_CHAT_MODEL_ID="gpt-4o"

# =============================================================================
# Optional: Azure AI Vision (Required only for image translation with -img flag)
# =============================================================================
# AZURE_AI_SERVICE_API_KEY="your_azure_ai_service_api_key"
# AZURE_AI_SERVICE_ENDPOINT="https://your_endpoint.cognitiveservices.azure.com/"
